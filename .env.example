# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────
# Acesse: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número do sandbox Twilio WhatsApp (ou seu número aprovado)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Gmail ────────────────────────────────────────────────────────────────
# Seu e-mail Gmail
GMAIL_USER=seuemail@gmail.com
# Senha de App (não é sua senha normal!)
# Gere em: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Banco de dados (Railway PostgreSQL) ──────────────────────────────────
# Cole aqui a DATABASE_URL gerada pelo Railway (aba Variables do Postgres)
DATABASE_URL=postgresql://postgres:senha@host.railway.app:5432/railway

# ─── Admin / Professor ────────────────────────────────────────────────────
# Login do professor (não precisa ser cadastrado como aluno)
ADMIN_EMAIL=professor@academia.com
ADMIN_PASSWORD=suasenhasecreta

# ─── JWT ──────────────────────────────────────────────────────────────────
# Chave secreta para assinar os tokens (mude para algo aleatório!)
JWT_SECRET=troque-por-uma-chave-secreta-longa

# ─── Servidor ─────────────────────────────────────────────────────────────
PORT=3001
